<!DOCTYPE html>
<html lang="ko">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>윷놀이</title>
<style>
  * { box-sizing: border-box; margin: 0; padding: 0; }
  body {
    font-family: 'Noto Sans KR', 'Apple SD Gothic Neo', sans-serif;
    background: #1a1a2e;
    color: #eee;
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    align-items: center;
  }
  h1 { font-size: 2.8rem; text-align: center; color: #f8c94f; text-shadow: 0 2px 8px #0006; letter-spacing: 6px; }
  .subtitle { color: #aaa; font-size: 0.85rem; text-align: center; margin-bottom: 16px; }

  /* ── 화면 전환 ── */
  .screen { display: none; width: 100%; max-width: 1400px; padding: 20px; }
  .screen.active { display: flex; flex-direction: column; align-items: center; }

  /* ── 시작 화면 ── */
  #setup-screen { gap: 18px; padding-top: 40px; }
  .setup-card {
    background: #16213e;
    border: 1px solid #2a2a5e;
    border-radius: 16px;
    padding: 36px 44px;
    width: 100%;
    max-width: 560px;
  }
  .setup-card h2 { font-size: 1.4rem; color: #f8c94f; margin-bottom: 20px; text-align: center; }
  .player-count-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 10px;
  }
  .cnt-btn {
    padding: 16px 0;
    border: 2px solid #2a2a5e;
    border-radius: 12px;
    background: #0f3460;
    color: #ccc;
    font-size: 1.4rem;
    font-weight: bold;
    cursor: pointer;
    transition: all .2s;
  }
  .cnt-btn:hover { border-color: #f8c94f; color: #f8c94f; }
  .cnt-btn.selected { border-color: #f8c94f; background: #2a1d00; color: #f8c94f; }
  .player-names { display: flex; flex-direction: column; gap: 8px; margin-top: 16px; }
  .player-names input {
    padding: 12px 18px;
    border-radius: 10px;
    border: 1px solid #2a2a5e;
    background: #0d1b2a;
    color: #eee;
    font-size: 1.1rem;
    outline: none;
    transition: border .2s;
    flex: 1;
  }
  .player-names input:focus { border-color: #f8c94f; }
  .team-color-dot {
    display: inline-block;
    width: 12px; height: 12px;
    border-radius: 50%;
    margin-right: 6px;
    vertical-align: middle;
  }
  .start-btn {
    padding: 18px 60px;
    background: linear-gradient(135deg, #e67e22, #f8c94f);
    color: #1a1a2e;
    font-size: 1.35rem;
    font-weight: bold;
    border: none;
    border-radius: 14px;
    cursor: pointer;
    letter-spacing: 3px;
    transition: transform .15s, box-shadow .15s;
    box-shadow: 0 4px 18px #f8c94f44;
  }
  .start-btn:hover { transform: scale(1.04); box-shadow: 0 6px 24px #f8c94f66; }

  /* ── 규칙 버튼 ── */
  .rules-btn {
    padding: 8px 22px;
    background: transparent;
    color: #aaa;
    border: 1px solid #444;
    border-radius: 8px;
    cursor: pointer;
    font-size: 0.9rem;
    transition: all .2s;
  }
  .rules-btn:hover { color: #f8c94f; border-color: #f8c94f; }

  /* ── 게임 화면 ── */
  #game-screen { flex-direction: row; align-items: flex-start; gap: 24px; flex-wrap: wrap; padding-top: 16px; }

  /* ── 보드 ── */
  .board-wrap { flex: 1 1 500px; display: flex; flex-direction: column; align-items: center; }
  #board-svg { width: 100%; max-width: 680px; height: auto; }

  /* ── 사이드 패널 ── */
  .side-panel { flex: 0 0 340px; display: flex; flex-direction: column; gap: 14px; }

  /* ── 현재 턴 ── */
  .turn-card {
    background: #16213e;
    border-radius: 14px;
    padding: 14px 16px;
    border: 1px solid #2a2a5e;
    text-align: center;
  }
  .turn-label { font-size: 0.95rem; color: #888; margin-bottom: 6px; }
  .turn-name { font-size: 1.9rem; font-weight: bold; }
  .turn-sub { font-size: 1rem; color: #aaa; margin-top: 6px; }

  /* ── 윷 던지기 오버레이 ── */
  #throw-overlay {
    position: fixed; inset: 0;
    background: rgba(5,8,20,0.88);
    display: none;
    align-items: center;
    justify-content: center;
    z-index: 200;
    flex-direction: column;
    gap: 0;
  }
  #throw-overlay.open { display: flex; }
  #throw-svg-wrap {
    width: min(500px, 90vw);
    height: min(500px, 90vw);
    position: relative;
  }
  #throw-svg-wrap svg { width: 100%; height: 100%; }
  #overlay-result {
    font-size: clamp(2.8rem, 8vw, 5rem);
    font-weight: bold;
    color: #f8c94f;
    letter-spacing: 6px;
    text-shadow: 0 0 30px #f8c94f88;
    opacity: 0;
    transform: scale(0.6);
    transition: opacity .35s, transform .35s;
    text-align: center;
    margin-top: 12px;
  }
  #overlay-result.show { opacity: 1; transform: scale(1); }
  #overlay-sub {
    font-size: 1.1rem;
    color: #aaa;
    margin-top: 8px;
    opacity: 0;
    transition: opacity .4s .15s;
    text-align: center;
  }
  #overlay-sub.show { opacity: 1; }

  /* ── 윷 던지기 ── */
  .throw-card {
    background: #16213e;
    border-radius: 14px;
    padding: 16px;
    border: 1px solid #2a2a5e;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 12px;
  }
  .yut-display { display: flex; gap: 12px; justify-content: center; min-height: 80px; align-items: center; }
  .yut-stick {
    width: 26px; height: 90px;
    border-radius: 13px;
    display: flex; align-items: center; justify-content: center;
    font-size: 12px;
    transition: transform .3s;
  }
  .yut-stick.flat { background: #c8a96e; border: 2px solid #a07840; }
  .yut-stick.round { background: #3d2b1f; border: 2px solid #5c3d2e; }
  .result-badge {
    font-size: 2.2rem;
    font-weight: bold;
    color: #f8c94f;
    min-height: 48px;
    display: flex;
    align-items: center;
    justify-content: center;
    letter-spacing: 3px;
  }
  .throw-btn {
    padding: 16px 44px;
    background: linear-gradient(135deg, #c0392b, #e74c3c);
    color: #fff;
    font-size: 1.25rem;
    font-weight: bold;
    border: none;
    border-radius: 12px;
    cursor: pointer;
    letter-spacing: 1px;
    transition: transform .15s, box-shadow .15s;
    box-shadow: 0 3px 12px #e74c3c44;
    width: 100%;
  }
  .throw-btn:hover:not(:disabled) { transform: scale(1.05); }
  .throw-btn:disabled { opacity: .5; cursor: not-allowed; transform: none; }

  /* ── 말 선택 ── */
  .piece-card {
    background: #16213e;
    border-radius: 14px;
    padding: 14px 16px;
    border: 1px solid #2a2a5e;
  }
  .piece-card h3 { font-size: 1rem; color: #aaa; margin-bottom: 12px; text-align: center; }
  .piece-list { display: flex; flex-wrap: wrap; gap: 10px; justify-content: center; }
  .piece-btn {
    padding: 10px 20px;
    border-radius: 10px;
    border: 2px solid transparent;
    font-size: 1rem;
    cursor: pointer;
    transition: all .2s;
    font-weight: bold;
  }
  .piece-btn:disabled { opacity: .4; cursor: not-allowed; }

  /* ── 점수판 ── */
  .score-card {
    background: #16213e;
    border-radius: 14px;
    padding: 18px 20px;
    border: 1px solid #2a2a5e;
  }
  .score-card h3 { font-size: 1rem; color: #aaa; margin-bottom: 12px; text-align: center; }
  .score-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 8px 0;
    border-bottom: 1px solid #1e2a3a;
    font-size: 1.05rem;
  }
  .score-row:last-child { border-bottom: none; }
  .score-name { display: flex; align-items: center; gap: 8px; }
  .color-dot { width: 13px; height: 13px; border-radius: 50%; }
  .score-val { font-weight: bold; color: #f8c94f; font-size: 1.1rem; }

  /* ── 로그 ── */
  .log-card {
    background: #16213e;
    border-radius: 14px;
    padding: 16px 20px;
    border: 1px solid #2a2a5e;
    max-height: 180px;
    overflow-y: auto;
  }
  .log-card h3 { font-size: 1rem; color: #aaa; margin-bottom: 10px; }
  .log-item { font-size: 0.92rem; color: #ccc; padding: 4px 0; border-bottom: 1px solid #1e2a3a; }
  .log-item:last-child { border-bottom: none; }

  /* ── 규칙 모달 ── */
  .modal-overlay {
    position: fixed; inset: 0;
    background: #000a;
    display: none;
    align-items: center;
    justify-content: center;
    z-index: 100;
  }
  .modal-overlay.open { display: flex; }
  .modal {
    background: #16213e;
    border: 1px solid #2a2a5e;
    border-radius: 18px;
    padding: 28px;
    max-width: 520px;
    width: 92%;
    max-height: 80vh;
    overflow-y: auto;
    position: relative;
  }
  .modal h2 { color: #f8c94f; font-size: 1.2rem; margin-bottom: 16px; text-align: center; }
  .modal-close {
    position: absolute; top: 14px; right: 16px;
    background: none; border: none; color: #aaa;
    font-size: 1.4rem; cursor: pointer;
  }
  .rule-section { margin-bottom: 14px; }
  .rule-section h3 { color: #f8c94f; font-size: 0.95rem; margin-bottom: 6px; }
  .rule-section p, .rule-section li { font-size: 0.88rem; color: #ccc; line-height: 1.7; }
  .rule-section ul { padding-left: 16px; }
  .yut-table { width: 100%; border-collapse: collapse; font-size: 0.85rem; margin-top: 6px; }
  .yut-table th { background: #0f3460; color: #f8c94f; padding: 6px 8px; text-align: center; }
  .yut-table td { padding: 5px 8px; text-align: center; border-bottom: 1px solid #2a2a5e; color: #ccc; }

  /* ── 승리 모달 ── */
  .win-modal {
    background: linear-gradient(135deg, #1a1a2e, #16213e);
    border: 2px solid #f8c94f;
    border-radius: 20px;
    padding: 36px;
    text-align: center;
    max-width: 360px;
    width: 92%;
  }
  .win-modal h2 { font-size: 2rem; color: #f8c94f; margin-bottom: 8px; }
  .win-modal p { color: #ccc; margin-bottom: 20px; }
  .win-modal .restart-btn {
    padding: 12px 36px;
    background: linear-gradient(135deg, #e67e22, #f8c94f);
    color: #1a1a2e;
    font-size: 1rem;
    font-weight: bold;
    border: none;
    border-radius: 10px;
    cursor: pointer;
    transition: transform .15s;
  }
  .win-modal .restart-btn:hover { transform: scale(1.05); }

  /* ── 상단바 ── */
  .top-bar { display: flex; align-items: center; justify-content: space-between; width: 100%; max-width: 1400px; padding: 16px 20px 4px; }
  .bonus-queue { display: flex; gap: 6px; align-items: center; flex-wrap: wrap; }
  .bonus-badge {
    background: #2a1d00; border: 1px solid #f8c94f;
    color: #f8c94f; border-radius: 8px;
    padding: 3px 10px; font-size: 0.8rem; font-weight: bold;
  }

  @media (max-width: 900px) {
    #game-screen { flex-direction: column; }
    .side-panel { flex: none; width: 100%; }
    h1 { font-size: 1.8rem; }
    #board-svg { max-width: 100%; }
  }
</style>
</head>
<body>

<!-- 상단 타이틀 -->
<div style="padding: 20px 16px 4px; text-align:center;">
  <h1>🎋 윷놀이</h1>
  <p class="subtitle">전통 보드게임 | 최대 8명</p>
</div>

<!-- ───────────── 설정 화면 ───────────── -->
<div id="setup-screen" class="screen active">
  <div class="setup-card">
    <h2>참여 인원을 선택하세요</h2>
    <div class="player-count-grid" id="cnt-grid"></div>
    <div class="player-names" id="name-inputs"></div>
  </div>
  <div style="display:flex; gap:12px; flex-wrap:wrap; justify-content:center;">
    <button class="start-btn" onclick="startGame()">게임 시작</button>
    <button class="rules-btn" onclick="openRules()">📖 규칙 보기</button>
  </div>
</div>

<!-- ───────────── 게임 화면 ───────────── -->
<div class="top-bar" id="top-bar" style="display:none;">
  <button class="rules-btn" onclick="openRules()" style="font-size:.8rem; padding:6px 14px;">📖 규칙</button>
  <div class="bonus-queue" id="bonus-queue"></div>
  <button class="rules-btn" onclick="goSetup()" style="font-size:.8rem; padding:6px 14px;">↩ 처음으로</button>
</div>

<div id="game-screen" class="screen">
  <!-- 보드 -->
  <div class="board-wrap">
    <svg id="board-svg" viewBox="0 0 660 660" xmlns="http://www.w3.org/2000/svg"></svg>
  </div>

  <!-- 사이드 패널 -->
  <div class="side-panel">
    <div class="turn-card">
      <div class="turn-label">현재 차례</div>
      <div class="turn-name" id="turn-name">-</div>
      <div class="turn-sub" id="turn-sub">윷을 던지세요</div>
    </div>

    <div class="throw-card">
      <div class="yut-display" id="yut-display">
        <span style="color:#666; font-size:0.85rem;">던지기 전</span>
      </div>
      <div class="result-badge" id="result-badge"></div>
      <button class="throw-btn" id="throw-btn" onclick="throwYut()">🎋 윷 던지기</button>
    </div>

    <div class="piece-card" id="piece-card" style="display:none;">
      <h3>움직일 말을 선택하세요</h3>
      <div class="piece-list" id="piece-list"></div>
      <div id="shortcut-dialog" style="display:none; margin-top:10px; background:#0f2035; border-radius:10px; padding:14px;"></div>
    </div>

    <div class="score-card">
      <h3>점수판</h3>
      <div id="score-board"></div>
    </div>

    <div class="log-card">
      <h3>기록</h3>
      <div id="game-log"></div>
    </div>
  </div>
</div>

<!-- ───────────── 규칙 모달 ───────────── -->
<div class="modal-overlay" id="rules-modal">
  <div class="modal">
    <button class="modal-close" onclick="closeRules()">✕</button>
    <h2>📖 윷놀이 규칙</h2>
    <div class="rule-section">
      <h3>🎯 목표</h3>
      <p>4개의 말을 모두 출발점에서 출발해 보드를 한 바퀴 돌아 먼저 골인시키는 팀이 이깁니다.</p>
    </div>
    <div class="rule-section">
      <h3>🎋 윷 결과</h3>
      <table class="yut-table">
        <tr><th>이름</th><th>엎어진 수</th><th>이동 칸</th><th>특징</th></tr>
        <tr><td>도</td><td>1개</td><td>1칸</td><td></td></tr>
        <tr><td>개</td><td>2개</td><td>2칸</td><td></td></tr>
        <tr><td>걸</td><td>3개</td><td>3칸</td><td></td></tr>
        <tr><td>윷</td><td>4개</td><td>4칸</td><td>한 번 더!</td></tr>
        <tr><td>모</td><td>0개</td><td>5칸</td><td>한 번 더!</td></tr>
        <tr><td>빽도</td><td>1개(특수)</td><td>-1칸</td><td>뒤로 이동</td></tr>
      </table>
    </div>
    <div class="rule-section">
      <h3>📌 주요 규칙</h3>
      <ul>
        <li><b>윷 또는 모</b>가 나오면 한 번 더 던질 수 있습니다.</li>
        <li>상대 말을 잡으면 한 번 더 던질 수 있습니다.</li>
        <li>같은 편 말 위에 내 말이 오면 <b>업어서</b> 함께 이동할 수 있습니다.</li>
        <li>모든 말이 골인해야 승리합니다.</li>
      </ul>
    </div>
    <div class="rule-section">
      <h3>🗺 지름길</h3>
      <ul>
        <li><b>10번 칸</b> (오른쪽 모서리): 대각선 지름길로 진입 가능</li>
        <li><b>20번 칸</b> (위 모서리): 대각선 지름길로 진입 가능</li>
        <li><b>25번 칸</b> (중앙): 지름길이 교차하는 지점</li>
      </ul>
    </div>
    <div style="text-align:center; margin-top:16px;">
      <button class="start-btn" style="padding:10px 32px; font-size:0.95rem;" onclick="closeRules()">확인</button>
    </div>
  </div>
</div>

<!-- ───────────── 윷 던지기 오버레이 ───────────── -->
<div id="throw-overlay">
  <div id="throw-svg-wrap">
    <svg id="throw-svg" viewBox="0 0 500 500" xmlns="http://www.w3.org/2000/svg"></svg>
  </div>
  <div id="overlay-result"></div>
  <div id="overlay-sub"></div>
</div>

<!-- ───────────── 승리 모달 ───────────── -->
<div class="modal-overlay" id="win-modal">
  <div class="win-modal">
    <h2>🏆</h2>
    <h2 id="win-title">승리!</h2>
    <p id="win-desc"></p>
    <button class="restart-btn" onclick="goSetup()">다시 하기</button>
  </div>
</div>

<script>
// ══════════════════════════════════════════
//  상수 & 설정
// ══════════════════════════════════════════
const COLORS = ['#e74c3c','#3498db','#2ecc71','#f39c12','#9b59b6','#1abc9c','#e67e22','#e91e63'];
const COLOR_NAMES = ['빨강','파랑','초록','주황','보라','청록','갈색','분홍'];

// 보드 경로: 0~27 = 외곽(시작=0, 골인=출발전), 28~30 = 오른쪽 대각, 31~33 = 왼쪽 대각, 34=중앙
// 각 칸: {x, y, type}
const TOTAL_CELLS = 29; // 0~28 외곽 순환

// 외곽 29칸 좌표 (0=출발/골인 직전, 1~5 아래, 5=오른쪽모서리, ... 20=위모서리, 25=왼모서리)
// 실제 좌표 계산: 440x440 보드 기준
const PAD = 60;
const SZ  = 660;
const STEP = (SZ - PAD*2) / 5;  // 108px

const P = (gx, gy) => ({ x: PAD + gx*STEP, y: PAD + gy*STEP });
const CENTER = P(2.5, 2.5);

// ══════════════════════════════════════════
//  표준 윷놀이 보드 — 외곽 20칸
//  출발(START) = 오른하 = pos 0
//  시계반대방향:
//    pos 1~4  : 아래변 (오른→왼)
//    pos 5    : 왼하 모서리 ★
//    pos 6~9  : 왼변 (아래→위)
//    pos 10   : 왼상 모서리 ★
//    pos 11~14: 위변 (왼→오른)
//    pos 15   : 오른상 모서리 ★
//    pos 16~19: 오른변 (위→아래)
//    → 다시 START
// ══════════════════════════════════════════
const START_PT = P(5, 5);
const OUTER = [
  P(4,5), P(3,5), P(2,5), P(1,5),  // pos 1~4   아래변
  P(0,5),                            // pos 5     왼하★
  P(0,4), P(0,3), P(0,2), P(0,1),  // pos 6~9   왼변
  P(0,0),                            // pos 10    왼상★
  P(1,0), P(2,0), P(3,0), P(4,0),  // pos 11~14 위변
  P(5,0),                            // pos 15    오른상★
  P(5,1), P(5,2), P(5,3), P(5,4),  // pos 16~19 오른변
];
// OUTER[pos-1] = pos 위치 좌표 (pos 1~20)

// ══════════════════════════════════════════
//  지름길 — 각 경로 3칸 (중간1 + 중간2 + 중앙)
//
//  대각선 A: START(5,5) ↔ pos10(0,0)
//    격자점: (4,4) (3,3) (2,2) (1,1)  교차: 중앙(2.5,2.5)
//  대각선 B: pos5(0,5) ↔ pos15(5,0)
//    격자점: (1,4) (2,3) (3,2) (4,1)  교차: 중앙(2.5,2.5)
//
//  진입(모서리→중앙) 3칸:
//    START→중앙 : (4,4)→(3,3)→중앙   pos 100~102
//    pos15→중앙 : (4,1)→(3,2)→중앙   pos 110~112
//    pos10→중앙 : (1,1)→(2,2)→중앙   pos 120~122
//    pos5→중앙  : (1,4)→(2,3)→중앙   pos 130~132
//  출구(중앙→합류점) 3칸:
//    중앙→START : (3,3)→(4,4)→START  pos 150~152
//    중앙→pos5  : (2,3)→(1,4)→pos5  pos 160~162
//    중앙→pos15 : (3,2)→(4,1)→pos15 pos 170~172
//  중앙 대기: pos 145
// ══════════════════════════════════════════

// ── 진입 경로 ──
const SC_START = [ P(4,4), P(3,3), CENTER ];  // 100~102: START→중앙
const SC_R15   = [ P(4,1), P(3,2), CENTER ];  // 110~112: pos15→중앙
const SC_L10   = [ P(1,1), P(2,2), CENTER ];  // 120~122: pos10→중앙
const SC_L5    = [ P(1,4), P(2,3), CENTER ];  // 130~132: pos5→중앙

// ── 출구 경로 (중앙 다음 칸부터, 합류점 포함) ──
const SC_EXIT    = [ P(3,3), P(4,4), START_PT ];  // 150~152: 중앙→START
const SC_L10_OUT = [ P(2,3), P(1,4), OUTER[4]  ];  // 160~162: 중앙→pos5(왼하)
const SC_L5_OUT  = [ P(3,2), P(4,1), OUTER[14] ];  // 170~172: 중앙→pos15(오른상)

function getPieceCoord(piece) {
  const p = piece.pos;
  if(p===999) return null;
  if(p===0)   return null;
  if(p>=1  &&p<=20)  return OUTER[p-1];
  if(p>=100&&p<=102) return SC_START[p-100];
  if(p>=110&&p<=112) return SC_R15[p-110];
  if(p>=120&&p<=122) return SC_L10[p-120];
  if(p>=130&&p<=132) return SC_L5[p-130];
  if(p>=150&&p<=152) return SC_EXIT[p-150];
  if(p>=160&&p<=162) return SC_L10_OUT[p-160];
  if(p>=170&&p<=172) return SC_L5_OUT[p-170];
  if(p===145)        return CENTER;
  return null;
}

// ══════════════════════════════════════════
//  이동 함수
//  shortcut 값:
//   'start'   : START→중앙→완료
//   'r15'     : pos15→중앙→완료(START 방향)
//   'l10'     : pos10→중앙→pos5 합류 후 외곽 계속
//   'l5'      : pos5→중앙, 통과 시 pos15 합류 직진
//   'l5_exit' : pos5→중앙, 중앙에서 출발 방향으로 꺾기
// ══════════════════════════════════════════
function movePiece(piece, steps) {
  if(steps===-1) {
    if(piece.pos===0) return;
    if(piece.pos>=100&&piece.pos<=102){piece.pos===100?(piece.pos=0,piece.shortcut=null):piece.pos--;}
    else if(piece.pos>=110&&piece.pos<=112){piece.pos===110?(piece.pos=15,piece.shortcut=null):piece.pos--;}
    else if(piece.pos>=120&&piece.pos<=122){piece.pos===120?(piece.pos=10,piece.shortcut=null):piece.pos--;}
    else if(piece.pos>=130&&piece.pos<=132){piece.pos===130?(piece.pos=5,piece.shortcut=null):piece.pos--;}
    else if(piece.pos>=150&&piece.pos<=152){piece.pos===150?piece.pos=112:piece.pos--;}
    else if(piece.pos>=160&&piece.pos<=162){piece.pos===160?piece.pos=122:piece.pos--;}
    else if(piece.pos>=170&&piece.pos<=172){piece.pos===170?piece.pos=132:piece.pos--;}
    else if(piece.pos===145){piece.pos=132;}
    else{piece.pos--;if(piece.pos<1)piece.pos=20;}
    return;
  }

  for(let i=0;i<steps;i++) {
    if(piece.pos===999) break;

    // 진입 경로 내부 (100→101→102, 110→111→112, 120→121→122, 130→131→132)
    if(piece.pos>=100&&piece.pos<=101){piece.pos++;continue;}
    if(piece.pos>=110&&piece.pos<=111){piece.pos++;continue;}
    if(piece.pos>=120&&piece.pos<=121){piece.pos++;continue;}
    if(piece.pos>=130&&piece.pos<=131){piece.pos++;continue;}

    // 중앙 도달
    if(piece.pos===102){piece.pos=150;continue;}   // start → 출구(완료방향)
    if(piece.pos===112){piece.pos=150;continue;}   // r15   → 출구(완료방향)
    if(piece.pos===122){piece.pos=160;continue;}   // l10   → pos5 방향 출구
    if(piece.pos===132){                           // l5    → 중앙 통과/정지
      const rem=steps-i-1;
      if(rem===0){piece.pos=145;}                 // 정확히 중앙에서 멈춤 → 선택 대기
      else{piece.pos=(piece.shortcut==='l5_exit')?150:170;} // 통과: 방향 선택
      continue;
    }

    // 중앙 대기(145) → 이번 턴 방향 결정됨
    if(piece.pos===145){
      piece.pos=(piece.shortcut==='l5_exit')?150:170;continue;
    }

    // 출구 경로
    if(piece.pos>=150&&piece.pos<=151){piece.pos++;continue;}
    if(piece.pos===152){piece.pos=999;break;}      // START 도달 → 완료

    if(piece.pos>=160&&piece.pos<=161){piece.pos++;continue;}
    if(piece.pos===162){piece.pos=5;piece.shortcut=null;continue;}  // pos5 합류

    if(piece.pos>=170&&piece.pos<=171){piece.pos++;continue;}
    if(piece.pos===172){piece.pos=15;piece.shortcut=null;continue;} // pos15 합류

    // 출발칸 → 항상 외곽으로
    if(piece.pos===0){ piece.pos=1; continue; }

    // 외곽 이동
    piece.pos++;
    if(piece.pos>20){piece.pos=999;break;}
    if     (piece.pos===5 &&piece.shortcut==='l5' ) piece.pos=130;
    else if(piece.pos===10&&piece.shortcut==='l10') piece.pos=120;
    else if(piece.pos===15&&piece.shortcut==='r15') piece.pos=110;
  }
}

function willPassShortcut(piece,steps) {
  if(steps<=0) return null;
  if(piece.pos===145) return {corner:'center',key:'center'};
  if(piece.pos>=1&&piece.pos<=20){
    for(let s=1;s<=steps;s++){
      const nxt=piece.pos+s;
      if(nxt===5)  return {corner:5, key:'l5'};
      if(nxt===10) return {corner:10,key:'l10'};
      if(nxt===15) return {corner:15,key:'r15'};
    }
  }
  return null;
}



function selectPiece(pieceIdx, shortcutChoice) {
  const player = players[currentPlayer];
  const piece = player.pieces[pieceIdx];
  const steps = YUT_MOVES[throwResult];
  const allIdxs = [pieceIdx, ...(piece.stackedWith || [])];

  // 지름길 모서리를 지나는지 확인 (shortcutChoice 미결정 시)
  if(shortcutChoice === undefined && steps > 0) {
    const sc = willPassShortcut(piece, steps);
    if(sc) {
      showShortcutDialog(pieceIdx, sc);
      return; // 사용자 선택 대기
    }
  }

  // shortcut 플래그 설정
  piece.shortcut = shortcutChoice || null;
  allIdxs.forEach(i => { player.pieces[i].shortcut = piece.shortcut; });

  // 리더 이동
  movePiece(piece, steps);

  // 업힌 말 동기화
  allIdxs.slice(1).forEach(i => {
    player.pieces[i].pos = piece.pos;
    player.pieces[i].shortcut = piece.shortcut;
  });

  // ── 같은 팀 말 업기 체크 ──
  if(piece.pos !== 999 && piece.pos !== 0) {
    player.pieces.forEach((other, oi) => {
      if(allIdxs.includes(oi)) return;
      if(other.pos !== piece.pos || other.pos === 0 || other.pos === 999) return;
      const otherIsRiding = player.pieces.some((p, pi) =>
        !allIdxs.includes(pi) && pi !== oi && (p.stackedWith || []).includes(oi)
      );
      if(otherIsRiding) return;
      const absorbIdxs = [oi, ...(other.stackedWith || [])];
      absorbIdxs.forEach(ai => { player.pieces[ai].stackedWith = []; });
      piece.stackedWith = [...(piece.stackedWith || []), ...absorbIdxs];
      absorbIdxs.forEach(ai => { player.pieces[ai].shortcut = piece.shortcut; });
      addLog('🔗 ' + player.name + ' 말' + (pieceIdx+1) + '이 말' + (oi+1) + '에 업혔습니다! (' + piece.stackedWith.length + '마리 묶음)');
    });
  }

  // ── 완료 처리 ──
  if(piece.pos === 999) {
    const finishedCount = allIdxs.length;
    player.finished += finishedCount;
    allIdxs.forEach(i => { player.pieces[i].stackedWith = []; });
    addLog('🎉 ' + player.name + ' 말 ' + finishedCount + '마리 골인! (' + player.finished + '/' + PIECE_COUNT + ')');
    if(player.finished >= PIECE_COUNT) {
      showWin(player);
      return;
    }
  } else {
    const stackCount = allIdxs.length;
    addLog(player.name + ': 말' + (pieceIdx+1) + (stackCount > 1 ? '외 ' + (stackCount-1) + '마리' : '') + ' → ' + YUT_NAMES[throwResult]);
  }

  // ── 상대 말 잡기 ──
  let captured = false;
  if(piece.pos !== 999 && piece.pos !== 0) {
    players.forEach((op, opi) => {
      if(opi === currentPlayer) return;
      op.pieces.forEach((op2, oi2) => {
        if(op2.pos !== piece.pos || op2.pos === 0 || op2.pos === 999) return;
        const isRiding = op.pieces.some((p, pi) => pi !== oi2 && (p.stackedWith || []).includes(oi2));
        if(isRiding) return;
        const capturedIdxs = [oi2, ...(op2.stackedWith || [])];
        capturedIdxs.forEach(ci => {
          op.pieces[ci].pos = 0;
          op.pieces[ci].shortcut = null;
          op.pieces[ci].stackedWith = [];
        });
        captured = true;
        addLog('⚔️ ' + player.name + '이 ' + op.name + '의 말 ' + capturedIdxs.length + '마리를 잡았습니다!');
      });
    });
  }

  document.getElementById('piece-card').style.display = 'none';
  document.getElementById('shortcut-dialog').style.display = 'none';

  if(captured) {
    bonusThrows.push('capture');
    addLog('💫 상대 말을 잡아 한 번 더!');
  }

  throwResult = null;
  throwDone = false;

  if(bonusThrows.length > 0) {
    bonusThrows.shift();
    updateBonusQueue();
    document.getElementById('throw-btn').disabled = false;
    updateTurnSub('한 번 더 던지세요!');
  } else {
    nextTurn();
  }

  drawBoard();
  updateUI();
}

