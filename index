// ══════════════════════════════════════════
//  윷 던지기
// ══════════════════════════════════════════
const YUT_NAMES = ['빽도','도','개','걸','윷','모'];
const YUT_MOVES = [-1, 1, 2, 3, 4, 5];
const YUT_COLORS = ['#e74c3c','#f39c12','#f8c94f','#2ecc71','#3498db','#9b59b6'];

// ── SVG 윷 막대 하나 그리기 ──
// cx,cy = 중심, angle = 기울기(rad), flat = 엎어진 면
function drawStickSVG(svg, cx, cy, angle, flat, alpha) {
  const ns = 'http://www.w3.org/2000/svg';
  const W = 36, H = 120, R = 18;
  const g = document.createElementNS(ns, 'g');
  g.setAttribute('transform', `translate(${cx},${cy}) rotate(${angle*180/Math.PI})`);
  g.setAttribute('opacity', alpha);

  // 그림자
  const sh = document.createElementNS(ns, 'rect');
  sh.setAttribute('x', -W/2+4); sh.setAttribute('y', -H/2+4);
  sh.setAttribute('width', W); sh.setAttribute('height', H);
  sh.setAttribute('rx', R); sh.setAttribute('fill', 'rgba(0,0,0,0.4)');
  g.appendChild(sh);

  // 몸통
  const body = document.createElementNS(ns, 'rect');
  body.setAttribute('x', -W/2); body.setAttribute('y', -H/2);
  body.setAttribute('width', W); body.setAttribute('height', H);
  body.setAttribute('rx', R);
  body.setAttribute('fill', flat ? '#d4a051' : '#4a2c1a');
  g.appendChild(body);

  // 하이라이트 (옆면 느낌)
  const hi = document.createElementNS(ns, 'rect');
  hi.setAttribute('x', -W/2+4); hi.setAttribute('y', -H/2+6);
  hi.setAttribute('width', 8); hi.setAttribute('height', H-12);
  hi.setAttribute('rx', 4);
  hi.setAttribute('fill', flat ? 'rgba(255,230,150,0.45)' : 'rgba(255,255,255,0.1)');
  g.appendChild(hi);

  // 평면/둥근 면 표시 텍스트
  const lbl = document.createElementNS(ns, 'text');
  lbl.setAttribute('x', 0); lbl.setAttribute('y', 5);
  lbl.setAttribute('text-anchor', 'middle');
  lbl.setAttribute('font-size', '20');
  lbl.setAttribute('font-weight', 'bold');
  lbl.setAttribute('fill', flat ? '#7a4a10' : '#c8a060');
  lbl.textContent = flat ? '앞' : '뒤';
  g.appendChild(lbl);

  svg.appendChild(g);
  return g;
}

// ── 파티클 효과 ──
function spawnParticles(svg, result) {
  const ns = 'http://www.w3.org/2000/svg';
  const color = YUT_COLORS[result];
  const cx = 250, cy = 250;
  for(let i=0; i<20; i++) {
    const c = document.createElementNS(ns, 'circle');
    const angle = (i/20)*Math.PI*2;
    const dist = 80 + Math.random()*120;
    const tx = cx + Math.cos(angle)*dist;
    const ty = cy + Math.sin(angle)*dist;
    const r = 4+Math.random()*6;
    c.setAttribute('cx', cx); c.setAttribute('cy', cy);
    c.setAttribute('r', r);
    c.setAttribute('fill', color);
    c.setAttribute('opacity', '0.9');
    svg.appendChild(c);

    const anim1 = document.createElementNS(ns, 'animateTransform');
    anim1.setAttribute('attributeName','transform');
    anim1.setAttribute('type','translate');
    anim1.setAttribute('from','0 0');
    anim1.setAttribute('to',`${tx-cx} ${ty-cy}`);
    anim1.setAttribute('dur','0.6s');
    anim1.setAttribute('fill','freeze');
    c.appendChild(anim1);

    const anim2 = document.createElementNS(ns, 'animate');
    anim2.setAttribute('attributeName','opacity');
    anim2.setAttribute('from','0.9');
    anim2.setAttribute('to','0');
    anim2.setAttribute('dur','0.6s');
    anim2.setAttribute('fill','freeze');
    c.appendChild(anim2);

    anim1.beginElement();
    anim2.beginElement();
  }
}

// ── 결과 확정 ──
function computeResult() {
  const r = Math.random();
  if(r < 0.04) return 4;       // 윷
  else if(r < 0.08) return 5;  // 모
  else if(r < 0.13) return 0;  // 빽도
  else if(r < 0.38) return 1;  // 도
  else if(r < 0.75) return 2;  // 개
  else return 3;                // 걸
}

function throwYut() {
  document.getElementById('throw-btn').disabled = true;

  const result = computeResult();
  const flats = result === 0 ? 1 : (result === 4 ? 4 : result === 5 ? 0 : result);

  const overlay = document.getElementById('throw-overlay');
  const svg = document.getElementById('throw-svg');
  const overlayResult = document.getElementById('overlay-result');
  const overlaySub = document.getElementById('overlay-sub');

  // 초기화
  svg.innerHTML = '';
  overlayResult.textContent = '';
  overlayResult.classList.remove('show');
  overlaySub.textContent = '';
  overlaySub.classList.remove('show');
  overlay.classList.add('open');

  // 윷 4개 초기 위치
  const positions = [
    {cx:155, cy:160}, {cx:250, cy:130},
    {cx:345, cy:160}, {cx:295, cy:260}
  ];
  const stickEls = [];

  // 초기 랜덤 상태로 그리기
  positions.forEach((p, i) => {
    const g = drawStickSVG(svg, p.cx, p.cy, (Math.random()*2-1)*0.8, Math.random()>0.5, 0.95);
    stickEls.push({el: g, cx: p.cx, cy: p.cy});
  });

  // ── 1단계: 굴리기 애니메이션 (CSS keyframes 대신 rAF 루프) ──
  const SPIN_DURATION = 900; // ms
  const start = performance.now();
  let settled = false;

  function spinFrame(now) {
    const elapsed = now - start;
    const t = Math.min(elapsed / SPIN_DURATION, 1);
    // easeOut
    const ease = 1 - Math.pow(1-t, 3);

    svg.innerHTML = '';

    positions.forEach((p, i) => {
      // 각 막대마다 다른 궤적
      const phase = i * Math.PI * 0.5;
      const spinAngle = (1-ease) * (Math.PI*4 + phase) * (i%2===0?1:-1);
      const scatter = (1-ease) * 40;
      const ox = Math.cos(phase*2)*scatter;
      const oy = Math.sin(phase*2)*scatter;

      // 결과에 따른 최종 면
      const isFinal = i < flats;
      // 아직 spinning → 랜덤, 정착 직전 → 결과
      const showFlat = t > 0.7 ? isFinal : (Math.random()>0.5);

      drawStickSVG(svg, p.cx+ox, p.cy+oy, spinAngle, showFlat, 0.9+ease*0.1);
    });

    if(t < 1) {
      requestAnimationFrame(spinFrame);
    } else if(!settled) {
      settled = true;
      showFinalState(svg, positions, flats, result, overlayResult, overlaySub);
    }
  }
  requestAnimationFrame(spinFrame);
}

function showFinalState(svg, positions, flats, result, overlayResult, overlaySub) {
  svg.innerHTML = '';

  // 결과 막대 최종 배치
  positions.forEach((p, i) => {
    drawStickSVG(svg, p.cx, p.cy, (Math.random()*0.25-0.125), i < flats, 1);
  });

  // 파티클
  spawnParticles(svg, result);

  // 결과 텍스트 표시
  const moveStr = YUT_MOVES[result] === -1 ? '(-1칸)' : `(+${YUT_MOVES[result]}칸)`;
  const isBig = result === 4 || result === 5;
  overlayResult.textContent = YUT_NAMES[result];
  overlayResult.style.color = YUT_COLORS[result];
  overlayResult.style.textShadow = `0 0 40px ${YUT_COLORS[result]}88`;
  setTimeout(() => overlayResult.classList.add('show'), 30);

  overlaySub.textContent = moveStr + (isBig ? ' 🎉 한 번 더!' : '');
  setTimeout(() => overlaySub.classList.add('show'), 80);

  // 1.5초 후 오버레이 닫고 게임 진행
  setTimeout(() => {
    document.getElementById('throw-overlay').classList.remove('open');
    resolveThrow(result);
  }, 1500);
}

function resolveThrow(result) {
  throwResult = result;
  throwDone = true;

  // 사이드패널 윷 막대 결과 표시
  const display = document.getElementById('yut-display');
  display.innerHTML = '';
  const flats = result === 0 ? 1 : (result === 4 ? 4 : result === 5 ? 0 : result);
  for(let i=0;i<4;i++){
    const s = document.createElement('div');
    s.className='yut-stick '+(i<flats?'flat':'round');
    s.style.transform='rotate('+(Math.random()*10-5)+'deg)';
    display.appendChild(s);
  }

  const badge = document.getElementById('result-badge');
  badge.textContent = YUT_NAMES[result] + (YUT_MOVES[result]===-1?' (-1)':' (+'+YUT_MOVES[result]+')');

  const isBonusTurn = result === 4 || result === 5;
  if(isBonusTurn) bonusThrows.push(result);

  updateTurnSub('말을 선택하세요');
  showPieceSelection();
  updateBonusQueue();
  // throw-btn은 말 선택(selectPiece) 완료 후 또는 nextTurn() 에서만 활성화
}

// ══════════════════════════════════════════
//  업기 헬퍼: 한 칸의 "리더" 말 목록 반환
//  (업힌 말들은 leader.stackedWith[] 에 pieceIdx 저장)
// ══════════════════════════════════════════

// 말 데이터: { pos, shortcut, stackedWith:[] }
// stackedWith: 같은 칸에 업혀있는 내 다른 말들의 인덱스 목록
// 리더 = stackedWith 를 가진 말 중 가장 먼저 그 칸에 온 말(첫 번째 말)
// 선택 UI: 리더 말만 보여주고, 리더 선택 시 stackedWith 포함 전체 이동

function getLeaderPieces(player) {
  const ridingSet = new Set();
  player.pieces.forEach(p => { (p.stackedWith || []).forEach(i => ridingSet.add(i)); });
  return player.pieces.map((p, i) => ({piece: p, idx: i, isLeader: !ridingSet.has(i)}))
    .filter(({piece, isLeader}) => isLeader && piece.pos !== 999);
}

function showPieceSelection() {
  const player = players[currentPlayer];
  const card = document.getElementById('piece-card');
  const list = document.getElementById('piece-list');
  card.style.display = 'block';
  list.innerHTML = '';
  document.getElementById('shortcut-dialog').style.display = 'none';
  document.getElementById('throw-btn').disabled = true;

  const steps = YUT_MOVES[throwResult];
  const leaders = getLeaderPieces(player);

  leaders.forEach(({piece, idx}) => {
    if(steps === -1 && piece.pos === 0) return;
    const btn = document.createElement('button');
    btn.className = 'piece-btn';
    btn.style.background = player.color + '22';
    btn.style.borderColor = player.color;
    btn.style.color = player.color;
    const stackCount = (piece.stackedWith||[]).length;
    const posLabel = piece.pos === 0 ? '대기' : piece.pos === 145 ? '중앙대기' : '칸 '+piece.pos;
    let label = '말'+(idx+1);
    if(stackCount > 0) label += '+'+stackCount+'마리 묶음';
    btn.textContent = label+' ('+posLabel+')';
    btn.onclick = () => selectPiece(idx);
    list.appendChild(btn);
  });

  if(list.children.length === 0) {
    const msg = document.createElement('div');
    msg.style.cssText = 'color:#aaa;font-size:.9rem;text-align:center;padding:8px;';
    msg.textContent = '이동 가능한 말이 없습니다. 턴을 넘깁니다.';
    list.appendChild(msg);
    setTimeout(() => {
      card.style.display = 'none';
      throwResult = null; throwDone = false;
      nextTurn(); drawBoard(); updateUI();
    }, 1500);
  }
}

function posKey(piece) {
  return piece.pos + ':' + (piece.shortcut || '');
}

// ══════════════════════════════════════════
//  말 선택
// ══════════════════════════════════════════
function nextTurn() {
  currentPlayer = (currentPlayer + 1) % players.length;
  throwResult = null;
  throwDone = false;
  document.getElementById('throw-btn').disabled = false;
  document.getElementById('result-badge').textContent = '';
  document.getElementById('yut-display').innerHTML = '<span style="color:#666;font-size:.85rem;">던지기 전</span>';
  updateTurnSub('윷을 던지세요');
}

// ══════════════════════════════════════════
//  UI 업데이트
// ══════════════════════════════════════════
function updateUI() {
  const p = players[currentPlayer];
  const nameEl = document.getElementById('turn-name');
  nameEl.textContent = p.name;
  nameEl.style.color = p.color;
  updateScoreBoard();
}

function updateTurnSub(text) {
  document.getElementById('turn-sub').textContent = text;
}

function updateBonusQueue() {
  const el = document.getElementById('bonus-queue');
  el.innerHTML = bonusThrows.length > 0
    ? '<span style="color:#aaa;font-size:.8rem;">보너스:</span>'
    : '';
  bonusThrows.forEach(b => {
    const span = document.createElement('span');
    span.className = 'bonus-badge';
    span.textContent = b === 'capture' ? '잡기 보너스' : YUT_NAMES[b]+' 보너스';
    el.appendChild(span);
  });
}

function updateScoreBoard() {
  const el = document.getElementById('score-board');
  el.innerHTML = '';
  players.forEach((p,i) => {
    const row = document.createElement('div');
    row.className='score-row';
    const isActive = i === currentPlayer;
    row.innerHTML = `
      <div class="score-name">
        <div class="color-dot" style="background:${p.color}"></div>
        <span style="color:${isActive?p.color:'inherit'}; font-weight:${isActive?'bold':'normal'}">${p.name}</span>
        ${isActive?'<span style="font-size:.7rem; color:'+p.color+'">▶</span>':''}
      </div>
      <span class="score-val">${p.finished}/${PIECE_COUNT}</span>
    `;
    el.appendChild(row);
  });
}

function addLog(msg) {
  const el = document.getElementById('game-log');
  const div = document.createElement('div');
  div.className = 'log-item';
  div.textContent = msg;
  el.insertBefore(div, el.firstChild);
  while(el.children.length > 20) el.removeChild(el.lastChild);
}

// ══════════════════════════════════════════
//  보드 그리기
// ══════════════════════════════════════════
function drawBoard() {
  const svg = document.getElementById('board-svg');
  svg.innerHTML = '';
  const ns = 'http://www.w3.org/2000/svg';
  function el(tag, attrs, parent) {
    const e = document.createElementNS(ns, tag);
    for(const [k,v] of Object.entries(attrs)) e.setAttribute(k,v);
    (parent||svg).appendChild(e); return e;
  }

  // ── 배경 ──
  el('rect',{x:0,y:0,width:660,height:660,fill:'#0d1b2a',rx:20});

  // ── 외곽 사각형 테두리 ──
  el('rect',{x:PAD,y:PAD,width:5*STEP,height:5*STEP,fill:'none',stroke:'#2a4a6e',strokeWidth:2});

  // ── 대각선 2개: START↔pos10(왼상), pos5(왼하)↔pos15(오른상) ──
  el('line',{x1:START_PT.x, y1:START_PT.y, x2:OUTER[9].x,  y2:OUTER[9].y,
    stroke:'#e67e22',strokeWidth:2,strokeDasharray:'8,5',opacity:.6});
  el('line',{x1:OUTER[4].x, y1:OUTER[4].y, x2:OUTER[14].x, y2:OUTER[14].y,
    stroke:'#e67e22',strokeWidth:2,strokeDasharray:'8,5',opacity:.6});

  // ── 지름길 중간 칸 (외곽 칸보다 먼저 그려 뒤에 깔리게) ──
  // 진입 4개 × 앞 2칸, 출구 3개 × 앞 2칸 (합류점은 외곽 칸이므로 제외)
  const midPts = [
    SC_START[0], SC_START[1],   // START→중앙
    SC_R15[0],   SC_R15[1],     // pos15→중앙
    SC_L10[0],   SC_L10[1],     // pos10→중앙
    SC_L5[0],    SC_L5[1],      // pos5→중앙
    SC_EXIT[0],  SC_EXIT[1],    // 중앙→START (앞 2칸, START_PT는 외곽)
    SC_L10_OUT[0], SC_L10_OUT[1], // 중앙→pos5 (앞 2칸, pos5는 외곽)
    SC_L5_OUT[0],  SC_L5_OUT[1],  // 중앙→pos15 (앞 2칸, pos15는 외곽)
  ];
  midPts.forEach(c => {
    el('circle',{cx:c.x,cy:c.y,r:12,fill:'#1e1000',stroke:'#e67e22',strokeWidth:1.5,opacity:.9});
  });

  // ── 외곽 칸: START ──
  el('circle',{cx:START_PT.x,cy:START_PT.y,r:22,fill:'#0f3020',stroke:'#2ecc71',strokeWidth:2.5});
  const stL=el('text',{x:START_PT.x,y:START_PT.y+1,'text-anchor':'middle','dominant-baseline':'middle',fill:'#2ecc71','font-size':11,'font-weight':'bold'});
  stL.textContent='출발';

  // ── 외곽 칸: pos 1~19 ──
  const CORNERS = new Set([5,10,15]);
  OUTER.forEach((c,i) => {
    const pos=i+1;
    const isCo=CORNERS.has(pos);
    el('circle',{cx:c.x,cy:c.y,r:isCo?22:16,
      fill:isCo?'#101a30':'#0a1525',
      stroke:isCo?'#f8c94f':'#2a4a6e',strokeWidth:isCo?2.5:2});
    const t=el('text',{x:c.x,y:c.y+1,'text-anchor':'middle','dominant-baseline':'middle',
      fill:isCo?'#f8c94f':'#4a7090','font-size':isCo?12:10});
    t.textContent=pos;
  });

  // ── 중앙 ──
  el('circle',{cx:CENTER.x,cy:CENTER.y,r:22,fill:'#201000',stroke:'#f8c94f',strokeWidth:2.5});
  const ct=el('text',{x:CENTER.x,y:CENTER.y+1,'text-anchor':'middle','dominant-baseline':'middle',fill:'#f8c94f','font-size':11,'font-weight':'bold'});
  ct.textContent='중앙';

  // ── 말 그리기 (리더 단위) ──
  const slotMap={};
  players.forEach((player,pi)=>{
    const ridingSet=new Set();
    player.pieces.forEach(p=>(p.stackedWith||[]).forEach(i=>ridingSet.add(i)));
    player.pieces.forEach((piece,pj)=>{
      if(ridingSet.has(pj)||piece.pos===0||piece.pos===999) return;
      const coord=getPieceCoord(piece);
      if(!coord) return;
      const key=Math.round(coord.x)+','+Math.round(coord.y);
      if(!slotMap[key]) slotMap[key]={coord,groups:[]};
      slotMap[key].groups.push({player,pi,pj,stackSize:1+(piece.stackedWith||[]).length});
    });
  });
  for(const [,{coord,groups}] of Object.entries(slotMap)){
    const {x:cx,y:cy}=coord, n=groups.length;
    groups.forEach(({player,pi,pj,stackSize},k)=>{
      const angle=n>1?(k/n)*Math.PI*2-Math.PI/2:0, off=n>1?14:0;
      const px2=cx+Math.cos(angle)*off, py2=cy+Math.sin(angle)*off;
      const r=stackSize>1?15:12;
      if(stackSize>1) el('circle',{cx:px2,cy:py2,r:r+4,fill:'none',stroke:player.color,strokeWidth:2.5,opacity:.5});
      el('circle',{cx:px2,cy:py2,r,fill:player.color,stroke:'#fff',strokeWidth:2});
      const t=el('text',{x:px2,y:py2+1,'text-anchor':'middle','dominant-baseline':'middle',fill:'#fff','font-size':stackSize>1?11:10,'font-weight':'bold'});
      t.textContent=stackSize>1?(pi+1)+'×'+stackSize:(pi+1)+'-'+(pj+1);
    });
  }

  // ── 대기 말 (보드 하단 여백) ──
  let waitX=PAD;
  players.forEach((player,pi)=>{
    player.pieces.filter(p=>p.pos===0).forEach(()=>{
      el('circle',{cx:waitX+13,cy:638,r:10,fill:player.color,stroke:'#fff',strokeWidth:1.5,opacity:.7});
      const t=el('text',{x:waitX+13,y:639,'text-anchor':'middle','dominant-baseline':'middle',fill:'#fff','font-size':9});
      t.textContent=(pi+1); waitX+=24;
    });
  });
}

// ══════════════════════════════════════════
