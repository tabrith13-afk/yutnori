function showWin(player) {
  document.getElementById('win-title').textContent = player.name + ' 승리!';
  document.getElementById('win-title').style.color = player.color;
  document.getElementById('win-desc').textContent = '모든 말을 골인했습니다! 🎊';
  document.getElementById('win-modal').classList.add('open');
  document.getElementById('throw-btn').disabled = true;
}

